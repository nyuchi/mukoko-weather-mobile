{
  "expo": {
    "name": "Mukoko Weather",
    "slug": "mukoko-weather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mukoko",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "africa.nyuchi.mukoko.weather",
      "supportsTablet": true
    },
    "android": {
      "package": "africa.nyuchi.mukoko.weather",
      "adaptiveIcon": {
        "backgroundColor": "#F3E5F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF9F5",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "dark": {
            "backgroundColor": "#1A0033",
            "image": "./assets/images/splash-icon-dark.png",
            "imageWidth": 220
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Mukoko Weather to use your location to show local weather conditions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "97f6eb48-2aac-42c2-b13d-5f68f1a86174"
      }
    },
    "owner": "nyuchi-web-services"
  }
}
