# Mukoko mobile env vars. Copy to `.env` and fill in.
# Anything prefixed EXPO_PUBLIC_ is inlined into the JS bundle at build time —
# do NOT put secrets here. Server-side secrets live in mukoko-weather.

# Base URL for the mukoko-weather Python API. Defaults to production.
# For local dev against a Next.js server on your LAN:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
EXPO_PUBLIC_API_URL=https://weather.mukoko.com

# WorkOS AuthKit hosted page (used by expo-auth-session for sign-in).
# Get these values from the WorkOS dashboard. The client ID is public-safe;
# the secret stays on the mukoko-weather server.
EXPO_PUBLIC_WORKOS_CLIENT_ID=client_REPLACE_ME
EXPO_PUBLIC_WORKOS_AUTHKIT_DOMAIN=https://auth.mukoko.com
